; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Blightsilver"
config/description="Hidden Grid Strategy Card Game"
config/version="0.1"
run/main_scene="res://scenes/splash_screen.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

AudioManager="*res://autoload/AudioManager.gd"
BGMManager="*res://autoload/BGMManager.gd"
BuildConfig="*res://autoload/BuildConfig.gd"
HudSkin="*res://autoload/HudSkin.gd"
UiTheme="*res://autoload/UiTheme.gd"
CardDatabase="*res://autoload/CardDatabase.gd"
UnionDatabase="*res://autoload/UnionDatabase.gd"
UnionScrollManager="*res://autoload/UnionScrollManager.gd"
GameState="*res://autoload/GameState.gd"
SaveManager="*res://autoload/SaveManager.gd"
MailboxManager="*res://autoload/MailboxManager.gd"
Collection="*res://autoload/Collection.gd"
ShopManager="*res://autoload/ShopManager.gd"
CampaignManager="*res://autoload/CampaignManager.gd"
DailyDungeonManager="*res://autoload/DailyDungeonManager.gd"
ExplorationManager="*res://autoload/ExplorationManager.gd"
ExplorationItemDatabase="*res://autoload/ExplorationItemDatabase.gd"
ExplorationPuzzleDatabase="*res://autoload/ExplorationPuzzleDatabase.gd"
CheckerTransition="*res://autoload/CheckerTransition.gd"
CardRuleEngine="*res://autoload/CardRuleEngine.gd"
AIvsAIManager="*res://autoload/AIvsAIManager.gd"
CardE2ERunner="*res://autoload/CardE2ERunner.gd"
SessionLogNaming="*res://autoload/SessionLogNaming.gd"
SFXManager="*res://autoload/SFXManager.gd"
MenuButtonConfig="*res://autoload/MenuButtonConfig.gd"
FontManager="*res://autoload/FontManager.gd"
GameDialog="*res://autoload/GameDialog.gd"
TutorialBattleManager="*res://autoload/TutorialBattleManager.gd"
OnboardingManager="*res://autoload/OnboardingManager.gd"
AIDeckVault="*res://autoload/AIDeckVault.gd"
QuickDuelRewards="*res://autoload/QuickDuelRewards.gd"
GlobalStatManager="*res://autoload/GlobalStatManager.gd"
AchievementManager="*res://autoload/AchievementManager.gd"
AchievementToaster="*res://autoload/AchievementToaster.gd"
RewardGranter="*res://autoload/RewardGranter.gd"
ProtagonistVault="*res://autoload/ProtagonistVault.gd"
AIIdentityVault="*res://autoload/AIIdentityVault.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/size/initial_position_type=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor]

movie_writer/movie_file="/Users/blightsilver/blightsilver_game/video/battle_magitech_ui_21111.avi"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot-sqlite/plugin.cfg", "res://addons/card_import_regen/plugin.cfg")

[input]

ui_accept={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194309,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":32,"physical_keycode":0,"key_label":0,"unicode":32,"location":0,"echo":false,"script":null)
, Object(InputEventJoypadButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"button_index":0,"pressure":0.0,"pressed":false,"script":null)
]
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
